\newcommand{\includethreeimages}[9]{
  \begin{figure}[!b]
    \centering
    \subfloat[#3]{\includegraphics[width=.2\textwidth]{#2}}
    \qquad
    \subfloat[#6]{\includegraphics[width=.2\textwidth]{#5}}
    \qquad
    \subfloat[#9]{\includegraphics[width=.2\textwidth]{#8}}
  \end{figure}
}

\newcommand{\includetwoimages}[6]{%
  \begin{figure}[!b]
    \centering
    \subfloat[#3]{\includegraphics[width=.2\textwidth]{#2}}
    \qquad
    \subfloat[#6]{\includegraphics[width=.2\textwidth]{#5}}
  \end{figure}%
}

\newcommand{\includeimage}[3]{
  \begin{figure}[H]
    \centering
    \includegraphics[width=0.2\textwidth]{#2}
    \captionsetup{width=0.2\textwidth}
    \caption{#3}
  \end{figure}
}

