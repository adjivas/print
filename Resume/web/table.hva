\newcommand\tabitem{}
\newcommand\tabsubitem{\textbullet{}}

\newstyle{.cellpading0}{
  overflow: hidden;
  display: block;
  width: 100\%;
}

\newstyle{.cellpading0 td:nth-child(2)}{
  width: 100\%;
}

\newstyle{.cellpading0 td:nth-child(1), .cellpading0 td:nth-child(2)}{
  white-space: normal !important;
}

\newstyle{.cellpading0 td:nth-child(3)}{
  white-space: nowrap !important;
}
