\RequirePackage{tikz}

\RequirePackage{fancyhdr}
\RequirePackage{hyperref}

\newcommand*\circled[1]{
  \tikz[baseline=(char.base)]{
    \node[shape=circle,draw,inner sep=3pt,line width=0.5pt] (char) {#1};
  }
}

\fancypagestyle{first}{%
  \fancyhf{}
  \fancyhead[C]{\raisebox{-3pt}{\hypersetup{extension=}\href{./blog.fr.pdf}{
    \Large\brushscriptregular{Navi’s Blog}}
  }}
  \fancyfoot[C]{%
    \hrulefill\hspace{-3pt}\raisebox{-3pt}{\scriptsize\circled{\gothic{\thepage}}}\hspace{-3pt}\hrulefill \\%
    \blogfooter{}
  }
  \renewcommand{\headrulewidth}{0pt}
}
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyhead[C]{\hrulefill\quad\raisebox{-3pt}{\hypersetup{extension=}\href{./blog.fr.pdf}{
    \Large\brushscriptregular{Navi’s Blog}}
  }\quad\hrulefill}
  \fancyfoot[C]{%
    \hrulefill\hspace{-3pt}\raisebox{-3pt}{\scriptsize\circled{\gothic{\thepage}}}\hspace{-3pt}\hrulefill \\%
    \blogfooter{}
  }
  \renewcommand{\headrulewidth}{0pt}
}
